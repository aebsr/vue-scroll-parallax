{
  "name": "vue-scroll-parallax",
  "version": "0.0.1",
  "description": "Vue 3 components and composables to create parallax scroll effects",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/vue-scroll-parallax.umd.js",
  "module": "./dist/vue-scroll-parallax.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-scroll-parallax.es.js",
      "require": "./dist/vue-scroll-parallax.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck": "vue-tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky install"
  },
  "dependencies": {
    "parallax-controller": "^1.7.1"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.2.0",
    "vite": "^5.4.18",
    "vite-plugin-dts": "^3.0.0",
    "vitepress": "^1.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.3.0",
    "vue-tsc": "^1.8.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^9.0.0",
    "@semantic-release/npm": "^11.0.0",
    "semantic-release": "^22.0.0",
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "scroll",
    "parallax",
    "animation",
    "effects",
    "typescript"
  ],
  "author": "Antoine Butler",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/vue-scroll-parallax"
  },
  "bugs": {
    "url": "https://github.com/yourusername/vue-scroll-parallax/issues"
  },
  "homepage": "https://github.com/yourusername/vue-scroll-parallax#readme",
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix",
    "*.{js,ts,vue,md,json}": "prettier --write"
  }
}
